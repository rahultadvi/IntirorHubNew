{
  "manifest_version": 3,
  "name": "IntirorHub",
  "version": "1.0.0",
  "description": "Interior design project management",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:*/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "IntirorHub"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
